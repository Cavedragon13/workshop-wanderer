# Security: Prevent access to development files
<FilesMatch "\.(json|py|md|sh)$">
    Order allow,deny
    Deny from all
</FilesMatch>

# Security: Disable directory browsing
Options -Indexes

# Performance: Enable compression for text files
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/html text/css text/javascript application/javascript
</IfModule>

# Performance: Browser caching for images
<IfModule mod_expires.c>
    ExpiresActive On
    ExpiresByType image/png "access plus 1 month"
    ExpiresByType image/jpeg "access plus 1 month"
    ExpiresByType image/jpg "access plus 1 month"
    ExpiresByType image/webp "access plus 1 month"
    ExpiresByType text/html "access plus 1 hour"
    ExpiresByType text/css "access plus 1 week"
    ExpiresByType application/javascript "access plus 1 week"
</IfModule>

# Performance: Set proper MIME types
<IfModule mod_mime.c>
    AddType image/webp .webp
</IfModule>
